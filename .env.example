APP_NAME="Orders Platform"
APP_ENV=local
APP_KEY=base64:GENERATE_WITH_ARTISAN_KEY_GENERATE
APP_DEBUG=true
APP_URL=http://localhost:8000

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=orders_platform
DB_USERNAME=app
DB_PASSWORD=secret

CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

REDIS_HOST=redis
REDIS_PORT=6379

JWT_SECRET=GENERATE_WITH_JWT_SECRET
JWT_TTL=60

L5_SWAGGER_GENERATE_ALWAYS=true
